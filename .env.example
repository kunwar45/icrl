# ── API keys ──────────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=your-key-here
OPENAI_API_KEY=your-key-here
HUGGINGFACE_TOKEN=your-key-here
TOGETHER_API_KEY=your-key-here

# ── Benchmark web apps (also set in ST-WebAgentBench/.env) ────────────────────
# Required for live browser episodes. SuiteCRM is the primary app for easy-tier tasks.
WA_SUITECRM=http://localhost:8080/public
# GITLAB=http://your-gitlab-instance:8023
# SHOPPING_ADMIN=http://your-shopping-admin:7780

# ── Paths (optional — setup_cluster.sh sets these in activate_icrl.sh) ────────
# STWEBAGENT_ROOT=/scratch/$USER/ST-WebAgentBench
# BROWSERGYM_ROOT=/scratch/$USER/BrowserGym

# ── W&B (optional) ────────────────────────────────────────────────────────────
# WANDB_API_KEY=your-key-here
# WANDB_ENTITY=your-entity-name
# WANDB_PROJECT=icrl-safety
